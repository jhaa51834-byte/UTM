# ═══════════════════════════════════════════════════════════════
# TrackFlow — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=TrackFlow
DEBUG=false
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trackflow:your_password@localhost:5432/trackflow
POSTGRES_PASSWORD=your_password

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=trackflow
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here-use-openssl-rand-hex-64
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── OAuth2 (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/microsoft/callback

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Providers (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Link Shortener ───────────────────────────────────────────
DEFAULT_SHORT_DOMAIN=go.yourdomain.com
SHORT_CODE_LENGTH=7

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── GeoIP (optional — download from MaxMind) ────────────────
GEOIP_DB_PATH=

# ── External Integrations ───────────────────────────────────
BITLY_TOKEN=

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@trackflow.io
